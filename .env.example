# AgenticAML Environment Configuration

# Database
DB_PATH=/app/data/aml.db

# OpenAI (optional - if not set, agents use rule-based logic only)
OPENAI_API_KEY=

# Thresholds (NGN)
CASH_THRESHOLD=5000000
TRANSFER_THRESHOLD=10000000
MATERIALITY_THRESHOLD=50000000

# Velocity limits
VELOCITY_WINDOW_HOURS=24
VELOCITY_MAX_TRANSACTIONS=10
VELOCITY_MAX_AMOUNT=20000000

# Structuring detection (% below threshold)
STRUCTURING_THRESHOLD_PCT=0.9

# Governance
CONFIDENCE_GATE_THRESHOLD=0.7
AUTO_BLOCK_SANCTIONS=true

# Application
APP_NAME=AgenticAML
APP_VERSION=1.0.0
INSTITUTION_NAME=Demo Bank Nigeria Ltd
INSTITUTION_CODE=DEMOBANK001
REPORTING_OFFICER=Chief Compliance Officer

# Port
PORT=8003
